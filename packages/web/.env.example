PUBLIC_SERVER_ORIGIN="localhost:4000" # url of the api (host[:port] or full http(s):// origin)
PUBLIC_SERVER_SECURE="0"             # set to "1" to force https/wss
# Optional: browser-only override (useful if SSR runs in Docker, but the browser should call the host)
PUBLIC_BROWSER_SERVER_ORIGIN=
PUBLIC_FRONTEND_CODE="anystring"    # Header code to include to mark request as from the frontend. Make sure to 
                                    # match this values with the one set for the server.
