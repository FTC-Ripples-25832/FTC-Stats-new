{
    "scripts": {
        "prepare": "husky install",
        "pretty": "prettier --write .",
        "common:watch": "npm run watch -w packages/common",
        "common:build": "npm run build -w packages/common",
        "common:check": "npm run check -w packages/common",
        "server:watch": "npm run watch -w packages/server",
        "server:build": "npm run build -w packages/server",
        "server:schema": "npm run schema -w packages/server",
        "server:dev": "npm run dev -w packages/server",
        "server:start": "npm run start -w packages/server",
        "server:check": "npm run check -w packages/server",
        "web:dev": "npm run dev -w packages/web",
        "web:build": "npm run build -w packages/web",
        "web:preview": "npm run preview -w packages/web",
        "web:check": "npm run check -w packages/web",
        "web:check:watch": "npm run check:watch -w packages/web",
        "web:gen": "npm run server:build && npm run server:schema && npm run gen -w packages/web",
        "web:start": "npm run start -w packages/web",
        "docker:up": "docker compose -f compose/docker-compose.full.yml up --build",
        "docker:up:detached": "docker compose -f compose/docker-compose.full.yml up -d --build",
        "docker:down": "docker compose -f compose/docker-compose.full.yml down",
        "docker:logs": "docker compose -f compose/docker-compose.full.yml logs -f --tail=200",
        "docker:ps": "docker compose -f compose/docker-compose.full.yml ps",
        "docker:rebuild": "docker compose -f compose/docker-compose.full.yml build --no-cache",
        "docker:db": "docker compose -f compose/docker-compose.yml up -d",
        "docker:db:down": "docker compose -f compose/docker-compose.yml down",
        "check": "npm run common:check && npm run server:check && npm run web:check"
    },
    "lint-staged": {
        "*.{ts,js,css,md,json,svelte,graphql}": "prettier --write"
    },
    "devDependencies": {
        "@types/graphql-fields": "^1.3.5",
        "husky": "^8.0.0",
        "lint-staged": "^13.2.2",
        "prettier": "^2.8.8",
        "prettier-plugin-svelte": "^2.10.1",
        "typescript": "^5.1.3"
    },
    "workspaces": [
        "packages/common",
        "packages/web",
        "packages/server"
    ],
    "dependencies": {
        "graphql": "^16.7.1",
        "graphql-fields": "^2.0.3"
    }
}
